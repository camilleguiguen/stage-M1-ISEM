# =============================================================================
# PanQueSt - Pipeline simplifié : multi-FASTA -> graphe Minigraph
# =============================================================================
#
# ENTRÉE  : un fichier multi-FASTA (1 record = 1 isolat)
# SORTIE  : <output_dir>/<run_name>/
#             ├── per_sample/<isolat>.fa     (1 FASTA par isolat)
#             ├── pangenome.gfa              (le graphe Minigraph)
#             ├── minigraph.log              (log d'exécution)
#             └── run_summary.txt            (résumé global)
# =============================================================================

from pathlib import Path

# --- 1. Chargement de la config ---------------------------------------------
configfile: "config/config.yaml"

# --- 2. Lecture du multi-FASTA pour récupérer la liste des isolats ----------
# 3 étapes :
#   a) lire tous les noms de records dans le multi-FASTA
#   b) appliquer le suffixe à virer (cosmétique, ex: "_chr1" -> rien)
#   c) restreindre aux N premiers si n_first est défini

def read_record_names(fasta_path):
    """Renvoie la liste ordonnée des noms de records (1er mot du header)."""
    names = []
    with open(fasta_path) as fh:
        for line in fh:
            if line.startswith(">"):
                names.append(line[1:].split()[0])
    return names

# (a) noms bruts dans le FASTA
RAW_NAMES = read_record_names(config["input"])

# (b) noms "propres" pour usage interne (fichiers, dossiers, références)
_suffix = config.get("strip_suffix")
if _suffix:
    CLEAN_NAMES = [n[:-len(_suffix)] if n.endswith(_suffix) else n
                   for n in RAW_NAMES]
else:
    CLEAN_NAMES = list(RAW_NAMES)

# Table de correspondance nom_propre -> nom_brut (pour samtools faidx)
NAME_MAP = dict(zip(CLEAN_NAMES, RAW_NAMES))

# (c) sélection sous-ensemble
_n = config.get("n_first")
if _n:
    SAMPLES = CLEAN_NAMES[:_n]
else:
    SAMPLES = CLEAN_NAMES

# Référence : config > premier de la liste
_ref_cfg = config.get("reference")
if _ref_cfg:
    if _ref_cfg not in SAMPLES:
        raise ValueError(
            f"Référence '{_ref_cfg}' introuvable parmi : {SAMPLES}"
        )
    REFERENCE = _ref_cfg
else:
    REFERENCE = SAMPLES[0]

RUN_DIR = Path(config["output_dir"]) / config["run_name"]

# Petit affichage au démarrage (visible dans la console)
onstart:
    print("=" * 60)
    print(f"  Run    : {config['run_name']}")
    print(f"  Input  : {config['input']}")
    print(f"  Total isolats dans le FASTA : {len(RAW_NAMES)}")
    print(f"  Sélectionnés ({len(SAMPLES)}) : {SAMPLES}")
    print(f"  Référence : {REFERENCE}")
    print("=" * 60)


# --- 3. Cible finale --------------------------------------------------------
# "rule all" liste ce qu'on veut obtenir à la fin.
# Snakemake remonte ensuite les dépendances tout seul.

rule all:
    input:
        str(RUN_DIR / "pangenome.gfa"),
        str(RUN_DIR / "run_summary.txt"),


# --- 4. Étape 1 : extraire chaque isolat dans son propre FASTA --------------
# samtools faidx extrait un record par son nom (= header brut du multi-FASTA).
# Le fichier de sortie est nommé avec le nom "propre" (suffixe viré).
# Cette règle tourne UNE FOIS PAR ISOLAT grâce à la wildcard {sample}.

rule extract_isolate:
    input:
        multifasta = config["input"],
    output:
        fa = str(RUN_DIR / "per_sample" / "{sample}.fa"),
    params:
        # nom brut à chercher dans le multi-FASTA (peut différer du sample
        # à cause de strip_suffix)
        raw_name = lambda wc: NAME_MAP[wc.sample],
    shell:
        """
        samtools faidx {input.multifasta} {params.raw_name} > {output.fa}
        """


# --- 5. Étape 2 : lancer Minigraph ------------------------------------------
# Minigraph est incrémental : on lui passe la référence en premier, puis le
# reste. On construit la liste de fichiers à la volée.

rule run_minigraph:
    input:
        # On demande tous les FASTA par isolat. expand() génère la liste :
        # ["results/test1/per_sample/A.fa", "results/test1/per_sample/B.fa", ...]
        fastas = expand(
            str(RUN_DIR / "per_sample" / "{sample}.fa"),
            sample=SAMPLES,
        ),
    output:
        gfa = str(RUN_DIR / "pangenome.gfa"),
        log = str(RUN_DIR / "minigraph.log"),
    params:
        min_sv_len = config["minigraph"]["min_sv_len"],
        ref_fa     = str(RUN_DIR / "per_sample" / f"{REFERENCE}.fa"),
        # autres FASTA = tous sauf la référence
        other_fas  = [
            str(RUN_DIR / "per_sample" / f"{s}.fa")
            for s in SAMPLES if s != REFERENCE
        ],
    threads:
        config["minigraph"]["threads"]
    shell:
        r"""
        START=$(date +%s)
        {{
          echo "===== Minigraph =====";
          echo "Date     : $(date)";
          echo "Version  : $(minigraph --version)";
          echo "Référence: {params.ref_fa}";
          echo "Autres   : {params.other_fas}";
          echo "Threads  : {threads}";
          echo "min SV   : {params.min_sv_len}";
          echo "---------------------";
        }} > {output.log}

        minigraph -cxggs -L {params.min_sv_len} -t {threads} \
            {params.ref_fa} {params.other_fas} \
            > {output.gfa} 2>> {output.log}

        END=$(date +%s)
        echo "---------------------" >> {output.log}
        echo "Durée: $((END-START)) s" >> {output.log}
        """


# --- 6. Étape 3 : construire un résumé du run -------------------------------

rule build_summary:
    input:
        gfa = str(RUN_DIR / "pangenome.gfa"),
        log = str(RUN_DIR / "minigraph.log"),
    output:
        summary = str(RUN_DIR / "run_summary.txt"),
    params:
        run_name = config["run_name"],
        samples  = SAMPLES,
        ref      = REFERENCE,
    script:
        "scripts/gfa_stats.py"
