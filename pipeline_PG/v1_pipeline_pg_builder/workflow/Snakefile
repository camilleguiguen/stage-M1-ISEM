# =============================================================================
# PanQueSt - Pipeline v1 : multi-FASTA -> graphe de pangénome
# =============================================================================
#
# ENTRÉE  : un fichier multi-FASTA (1 record = 1 isolat)
# SORTIE  : <output_dir>/<run_name>/
#             ├── per_sample/<isolat>.fa
#             ├── Minigraph/pangenome_MG.gfa  (si tools.minigraph: true)
#             ├── PGGB/pangenome.gfa          (si tools.pggb: true)
#             └── runs_summary_update.txt
# =============================================================================

from pathlib import Path

# --- 1. Chargement de la config ---------------------------------------------
configfile: "config/config.yaml"

# --- 2. Variables globales --------------------------------------------------

def read_record_names(fasta_path):
    names = []
    with open(fasta_path) as fh:
        for line in fh:
            if line.startswith(">"):
                names.append(line[1:].split()[0]) #On enlève le > (le [1:]), on coupe sur les espaces (split()), et on prend le premier mot ([0])
    return names

ALL_NAMES = read_record_names(config["input"])

# Sous-ensemble pour les tests : N premiers isolats (null/absent = tous)
n = config.get("n_first")
SAMPLES = ALL_NAMES[:n] if n else ALL_NAMES #prend le sous jeu de données

# Référence = isolat spécifié dans config, ou 1er de la sélection si null
REFERENCE = config.get("reference") or SAMPLES[0]

# Dossier de sortie du run
#pour l'instant (species, chrom, other) mais a terme je decouperais le nom de l'input
RUN_NAME = f"result_{config['species']}_chrom{config['chrom']}_{config['other']}"
RUN_DIR  = Path(config["output_dir"]) / RUN_NAME

# --- 3. Fonctions helper pour cibles/inputs conditionnels -------------------

def active_tools():
    # Retourne la liste des outils activés dans config["tools"],
    # chacun décrit par son label, son GFA de sortie et son log.
    # Point d'entrée unique : ajouter un outil ici suffit à tout propager.
    tools = []
    if config["tools"].get("minigraph", True): #ici true car "activé par défaut (contrairement a pggb qui ne dois pas etre lancé au hasard car lourd, il ne sera lancé que si le fichier de config l'indique)"
        tools.append({
            "label":   "Minigraph",
            "gfa":     str(RUN_DIR / "Minigraph" / "pangenome_MG.gfa"),
            "log":     str(RUN_DIR / "Minigraph" / "minigraph.log"),
            "bandage": str(RUN_DIR / "Minigraph" / "bandage_MG.png"),
        })
    if config["tools"].get("pggb", False):
        tools.append({
            "label":   "PGGB",
            "gfa":     str(RUN_DIR / "PGGB" / "pangenome.gfa"),
            "log":     str(RUN_DIR / "PGGB" / "pggb.log"),
            "bandage": str(RUN_DIR / "PGGB" / "visu_images" / "bandage.png"),
        })
    if config["tools"].get("minigraph_cactus", False):
        tools.append({
            "label":   "MinigraphCactus",
            "gfa":     str(RUN_DIR / "MinigraphCactus" / "pangenome_MC.gfa"),
            "log":     str(RUN_DIR / "MinigraphCactus" / "minigraph_cactus.log"),
            "bandage": str(RUN_DIR / "MinigraphCactus" / "bandage_MC.png"),
        })
    return tools

def get_targets():
    # Cibles finales de rule all : GFAs des outils actifs + le résumé.
    # Si visualisation: true, ajoute les images Bandage de chaque outil actif.
    targets = [t["gfa"] for t in active_tools()]
    targets.append(str(RUN_DIR / "runs_summary_update.txt"))
    if config["tools"].get("visualisation", False):
        targets += [t["bandage"] for t in active_tools()]
    return targets

def summary_gfas(wildcards):
    # Input gfas de build_summary : un GFA par outil actif.
    return [t["gfa"] for t in active_tools()]

def summary_logs(wildcards):
    # Input logs de build_summary : un log par outil actif, même ordre que summary_gfas.
    return [t["log"] for t in active_tools()]

def summary_labels(wildcards):
    # Params labels de build_summary : noms lisibles, même ordre que summary_gfas.
    return [t["label"] for t in active_tools()]

# --- 4. Affichage au démarrage ----------------------------------------------
onstart:
    tools_on = [k for k, v in config["tools"].items() if v]
    print("=" * 60)
    print(f"  Run    : {RUN_NAME}")
    print(f"  Input  : {config['input']}")
    print(f"  Total dans le FASTA : {len(ALL_NAMES)}")
    print(f"  Sélectionnés ({len(SAMPLES)}) : {SAMPLES}")
    print(f"  Référence : {REFERENCE}")
    print(f"  Outils    : {tools_on}")
    print("=" * 60)

# --- Affichage rappel commandes scp pour les visu à la fin du pipeline -----------------------------------------
onsuccess:
    import os
    user = os.getenv("USER", "user")
    print("\n" + "=" * 60)
    print("  Pipeline terminé !")
    print("  Pour rapatrier les résultats des visu en local :")
    print(f"  scp -r {user}@<login_node>:{RUN_DIR} .")
    print("  Pour l'instant pour camille (changer noms fic):")
    print ("    PATH_RES=//scratch/cguiguen/v1_pipeline_pg_builder/all_results/result_ecoli_chrom1_testv?/")
    print ("    scp -r cguiguen@genossh.genouest.org:$PATH_RES/PGGB/visu_images ~/Documents/data_from_cluster/")
    print ("    scp cguiguen@genossh.genouest.org:$PATH_RES/Minigraph/bandage_MG.png ~/Documents/data_from_cluster/ ")
    print("=" * 60 + "\n")

# --- 5. Cible finale --------------------------------------------------------
rule all:
    input:
        get_targets()

# --- 6. Règles par outil ----------------------------------------------------
include: "rules/minigraph.smk"
include: "rules/pggb.smk"
include: "rules/mini-cactus.smk"
include: "rules/report.smk"
include: "rules/visu.smk"
